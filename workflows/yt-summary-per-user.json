        "jsCode": "const fs = require('fs');\nconst STATE_PATH = '/workflows/state/processed.json';\nlet processed = {};\ntry { processed = JSON.parse(fs.readFileSync(STATE_PATH, 'utf8')); } catch (e) {}\nreturn $input.all().filter(i => !(i.json.videoId in processed));"
